@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Publicaciones";
    var idUsuarioActual = ViewBag.IdUsuario as string;
    var esAdmin = ViewBag.EsAdmin == true;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-megaphone me-2"></i>Publicaciones</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i> Nueva Publicaci&oacute;n</a>
</div>

<div id="map" style="height: 350px; border-radius: 12px; margin-bottom: 2rem;" class="shadow-sm"></div>

<div class="row">
    @foreach (var item in Model)
    {
        var idUsuarioPublicacion = item.GetProperty("idUsuario").GetInt32().ToString();
        var puedeEliminar = esAdmin || idUsuarioActual == idUsuarioPublicacion;

        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                @{
                    var imagen = item.TryGetProperty("imagen", out var imgProp) ? imgProp.GetString() : null;
                }
                @if (!string.IsNullOrEmpty(imagen))
                {
                    <img src="@imagen" class="card-img-top" alt="Imagen de publicación"
                         style="height: 200px; object-fit: cover;" />
                }
                else
                {
                    <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 120px; background: var(--accent-glow);">
                        <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@item.GetProperty("nombreMaterial").GetString()</h5>
                    <h6 class="card-subtitle mb-2 text-muted">
                        <i class="bi bi-person-circle me-1"></i>@item.GetProperty("correoUsuario").GetString()
                    </h6>
                    <p class="card-text text-secondary">@item.GetProperty("descripcion").GetString()</p>
                    <div class="d-flex gap-3 flex-wrap">
                        <span class="badge bg-success bg-opacity-10 text-success">
                            <i class="bi bi-box-seam me-1"></i>@item.GetProperty("cantidad").GetDecimal() kg
                        </span>
                        @if (item.TryGetProperty("ubicacion", out var ubi) && ubi.ValueKind != System.Text.Json.JsonValueKind.Null)
                        {
                            <span class="badge bg-info bg-opacity-10 text-info">
                                <i class="bi bi-geo-alt me-1"></i>@ubi.GetString()
                            </span>
                        }
                    </div>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-calendar me-1"></i>@item.GetProperty("fechaPublicacion").GetDateTime().ToLocalTime().ToString("dd/MM/yyyy")
                    </small>
                </div>
                @if (puedeEliminar)
                {
                    <div class="card-footer border-0 bg-transparent pt-0">
                        <form asp-action="Delete" method="post" onsubmit="return confirm('¿Eliminar esta publicaci\u00F3n?')">
                            <input type="hidden" name="id" value="@item.GetProperty("idPublicacion").GetInt32()" />
                            <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        var map = L.map('map').setView([14.6349, -90.5069], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var items = @Html.Raw(JsonSerializer.Serialize(Model.Select(p => new
        {
            lat = p.TryGetProperty("latitud", out var lt) && lt.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)lt.GetDecimal() : null,
            lng = p.TryGetProperty("longitud", out var ln) && ln.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)ln.GetDecimal() : null,
            nombre = p.GetProperty("nombreMaterial").GetString(),
            usuario = p.GetProperty("correoUsuario").GetString(),
            descripcion = p.GetProperty("descripcion").GetString(),
            cantidad = p.GetProperty("cantidad").GetDecimal(),
            ubicacion = p.GetProperty("ubicacion").GetString()
        })));

        var bounds = [];
        items.forEach(function (item) {
            if (item.lat && item.lng) {
                var marker = L.marker([item.lat, item.lng]).addTo(map);
                marker.bindPopup('<b>' + item.nombre + '</b><br/>' +
                    item.descripcion + '<br/>' +
                    item.cantidad + ' kg<br/>' +
                    (item.ubicacion || ''));
                bounds.push([item.lat, item.lng]);
            }
        });

        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [30, 30] });
        }
    </script>
}
