@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Centros de Reciclaje";
    var esAdmin = ViewBag.EsAdmin == true;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Centros de Reciclaje</h2>
    @if (esAdmin)
    {
        <a asp-action="Create" class="btn btn-success">+ Nuevo Centro</a>
    }
</div>

<div id="map" style="height: 400px; border-radius: 8px; margin-bottom: 2rem;"></div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">@item.GetProperty("nombreCentro").GetString()</h5>
                    <ul class="list-unstyled">
                        <li><strong>Direcci&oacute;n:</strong> @item.GetProperty("direccion").GetString()</li>
                        <li><strong>Tel&eacute;fono:</strong> @item.GetProperty("telefono").GetString()</li>
                        <li><strong>Capacidad:</strong> @item.GetProperty("capacidad").GetInt32() kg</li>
                    </ul>
                </div>
                @if (esAdmin)
                {
                    <div class="card-footer">
                        <a asp-action="Edit" asp-route-id="@item.GetProperty("idCentro").GetInt32()"
                           class="btn btn-warning btn-sm">Editar</a>
                        <form asp-action="Delete" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar este centro?')">
                            <input type="hidden" name="id" value="@item.GetProperty("idCentro").GetInt32()" />
                            <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        var map = L.map('map').setView([14.6349, -90.5069], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var items = @Html.Raw(JsonSerializer.Serialize(Model.Select(c => new
        {
            lat = c.TryGetProperty("latitud", out var lt) && lt.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)lt.GetDecimal() : null,
            lng = c.TryGetProperty("longitud", out var ln) && ln.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)ln.GetDecimal() : null,
            nombre = c.GetProperty("nombreCentro").GetString(),
            direccion = c.GetProperty("direccion").GetString()
        })));

        var bounds = [];
        items.forEach(function (item) {
            if (item.lat && item.lng) {
                var marker = L.marker([item.lat, item.lng]).addTo(map);
                marker.bindPopup('<b>' + item.nombre + '</b><br/>' + (item.direccion || ''));
                bounds.push([item.lat, item.lng]);
            }
        });

        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [30, 30] });
        }
    </script>
}
