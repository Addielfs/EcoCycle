@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Centros de Reciclaje";
    var esAdmin = ViewBag.EsAdmin == true;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-building me-2"></i>Centros de Reciclaje</h2>
    @if (esAdmin)
    {
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i> Nuevo Centro</a>
    }
</div>

<div id="map" style="height: 350px; border-radius: 12px; margin-bottom: 2rem;" class="shadow-sm"></div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4 fade-in">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center mb-3">
                        <div class="rounded-circle p-2 me-3" style="background: var(--accent-glow); width: 44px; height: 44px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-building text-success"></i>
                        </div>
                        <h5 class="card-title mb-0">@item.GetProperty("nombreCentro").GetString()</h5>
                    </div>
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-muted"></i>@item.GetProperty("direccion").GetString()</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2 text-muted"></i>@item.GetProperty("telefono").GetString()</li>
                        <li><i class="bi bi-box-seam me-2 text-muted"></i>Capacidad: <strong>@item.GetProperty("capacidad").GetInt32() kg</strong></li>
                    </ul>
                </div>
                @if (esAdmin)
                {
                    <div class="card-footer border-0 bg-transparent pt-0">
                        <a asp-action="Edit" asp-route-id="@item.GetProperty("idCentro").GetInt32()"
                           class="btn btn-warning btn-sm"><i class="bi bi-pencil me-1"></i>Editar</a>
                        <form asp-action="Delete" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar este centro?')">
                            <input type="hidden" name="id" value="@item.GetProperty("idCentro").GetInt32()" />
                            <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Eliminar</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        var map = L.map('map').setView([14.6349, -90.5069], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        var items = @Html.Raw(JsonSerializer.Serialize(Model.Select(c => new
        {
            lat = c.TryGetProperty("latitud", out var lt) && lt.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)lt.GetDecimal() : null,
            lng = c.TryGetProperty("longitud", out var ln) && ln.ValueKind == System.Text.Json.JsonValueKind.Number ? (decimal?)ln.GetDecimal() : null,
            nombre = c.GetProperty("nombreCentro").GetString(),
            direccion = c.GetProperty("direccion").GetString()
        })));

        var bounds = [];
        items.forEach(function (item) {
            if (item.lat && item.lng) {
                var marker = L.marker([item.lat, item.lng]).addTo(map);
                marker.bindPopup('<b>' + item.nombre + '</b><br/>' + (item.direccion || ''));
                bounds.push([item.lat, item.lng]);
            }
        });

        if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [30, 30] });
        }
    </script>
}
