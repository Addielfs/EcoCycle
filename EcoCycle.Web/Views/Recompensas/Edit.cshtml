@using System.Text.Json
@model JsonElement

@{
    ViewData["Title"] = "Editar Recompensa";
    var idRecompensa = Model.GetProperty("idRecompensa").GetInt32();
    var puntos = Model.GetProperty("puntos").GetInt32();
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Editar Recompensa</h2>
</div>

<div class="row justify-content-center fade-in">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="idRecompensa" value="@idRecompensa" />
                    <div class="mb-3">
                        <label class="form-label">Puntos</label>
                        <input type="number" name="puntos" class="form-control" value="@puntos" required min="1" />
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
