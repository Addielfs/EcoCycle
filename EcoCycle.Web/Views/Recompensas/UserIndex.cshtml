@using System.Text.Json
@model JsonElement

@{
    ViewData["Title"] = "Mis Recompensas";
}

<div class="row justify-content-center fade-in">
    <div class="col-md-8">
        <div class="card card-dashboard green shadow mb-4">
            <div class="card-body text-center py-5">
                <h5 class="card-title">Mis Puntos</h5>
                <h1 class="display-1" style="font-weight: 800; background: linear-gradient(135deg, var(--accent-green), var(--accent-teal)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
                    @try { @Model.GetProperty("totalPuntos").GetInt32() } catch { <text>0</text> }
                </h1>
                <p class="lead text-secondary">Puntos acumulados</p>
            </div>
        </div>

        <div class="card shadow">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Historial de Puntos</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Puntos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @try
                            {
                                var historial = Model.GetProperty("historial").EnumerateArray();
                                @foreach (var item in historial)
                                {
                                    <tr>
                                        <td>@item.GetProperty("fechaRegistro").GetString()</td>
                                        <td><span class="badge bg-success">+@item.GetProperty("puntos").GetInt32() pts</span></td>
                                    </tr>
                                }
                            }
                            catch
                            {
                                <tr>
                                    <td colspan="2" class="text-center py-4 text-muted">No hay registros de puntos</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
