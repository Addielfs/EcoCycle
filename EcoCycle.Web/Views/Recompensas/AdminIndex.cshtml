@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Recompensas";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-star me-2"></i>Recompensas</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i> Nueva Recompensa</a>
</div>

<div class="table-responsive fade-in">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Usuario</th>
                <th>Puntos</th>
                <th>Fecha</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.GetProperty("idRecompensa").GetInt32()</td>
                    <td>@item.GetProperty("idUsuario").GetInt32()</td>
                    <td><span class="badge bg-success">@item.GetProperty("puntos").GetInt32() pts</span></td>
                    <td class="text-secondary">@item.GetProperty("fechaRegistro").GetString()</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.GetProperty("idRecompensa").GetInt32()"
                           class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a>
                        <form asp-action="Delete" method="post" style="display:inline"
                              onsubmit="return confirm('¿Eliminar esta recompensa?')">
                            <input type="hidden" name="id" value="@item.GetProperty("idRecompensa").GetInt32()" />
                            <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
