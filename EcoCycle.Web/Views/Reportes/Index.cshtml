@using System.Text.Json
@model JsonElement

@{
    ViewData["Title"] = "Reportes";
}

<div class="page-header">
    <h2><i class="bi bi-bar-chart me-2"></i>Reporte General</h2>
</div>

<div class="row mt-4">
    <div class="col-md-4 mb-4 fade-in">
        <div class="card card-dashboard green">
            <div class="card-body text-center">
                <h5 class="card-title">Materiales</h5>
                <h2 class="display-4">@Model.GetProperty("totalMateriales").GetInt32()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4 fade-in" style="animation-delay: 0.1s">
        <div class="card card-dashboard blue">
            <div class="card-body text-center">
                <h5 class="card-title">Publicaciones</h5>
                <h2 class="display-4">@Model.GetProperty("totalPublicaciones").GetInt32()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4 fade-in" style="animation-delay: 0.2s">
        <div class="card card-dashboard purple">
            <div class="card-body text-center">
                <h5 class="card-title">Centros</h5>
                <h2 class="display-4">@Model.GetProperty("totalCentros").GetInt32()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4 fade-in" style="animation-delay: 0.3s">
        <div class="card card-dashboard orange">
            <div class="card-body text-center">
                <h5 class="card-title">Usuarios</h5>
                <h2 class="display-4">@Model.GetProperty("totalUsuarios").GetInt32()</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4 fade-in" style="animation-delay: 0.4s">
        <div class="card card-dashboard teal">
            <div class="card-body text-center">
                <h5 class="card-title">Puntos Totales</h5>
                <h2 class="display-4">@Model.GetProperty("totalPuntos").GetInt32()</h2>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mt-4 fade-in">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>&Uacute;ltimas Publicaciones</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Material</th>
                        <th>Usuario</th>
                        <th>Cantidad</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @try
                    {
                        var publicaciones = Model.GetProperty("ultimasPublicaciones").EnumerateArray();
                        @foreach (var pub in publicaciones)
                        {
                            <tr>
                                <td>@pub.GetProperty("idPublicacion").GetInt32()</td>
                                <td class="fw-semibold">@pub.GetProperty("nombreMaterial").GetString()</td>
                                <td>@pub.GetProperty("correoUsuario").GetString()</td>
                                <td>@pub.GetProperty("cantidad").GetDecimal() kg</td>
                                <td class="text-secondary">@pub.GetProperty("fechaPublicacion").GetDateTime().ToLocalTime().ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                    catch
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No hay publicaciones</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
