@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Materiales";
    var esAdmin = ViewBag.EsAdmin == true;
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h2><i class="bi bi-box me-2"></i>Materiales</h2>
    @if (esAdmin)
    {
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg me-1"></i> Nuevo Material</a>
    }
</div>

<div class="table-responsive fade-in">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Descripci&oacute;n</th>
                @if (esAdmin)
                {
                    <th class="text-end">Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.GetProperty("idMaterial").GetInt32()</td>
                    <td class="fw-semibold">@item.GetProperty("nombreMaterial").GetString()</td>
                    <td class="text-secondary">@item.GetProperty("descripcion").GetString()</td>
                    @if (esAdmin)
                    {
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.GetProperty("idMaterial").GetInt32()"
                               class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('¿Eliminar este material?')" style="display:inline">
                                <input type="hidden" name="id" value="@item.GetProperty("idMaterial").GetInt32()" />
                                <button type="submit" class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
