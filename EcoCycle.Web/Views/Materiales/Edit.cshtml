@using System.Text.Json
@model JsonElement

@{
    ViewData["Title"] = "Editar Material";
    var idMaterial = Model.GetProperty("idMaterial").GetInt32();
    var nombreMaterial = Model.GetProperty("nombreMaterial").GetString();
    var descripcion = Model.GetProperty("descripcion").GetString();
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2"></i>Editar Material</h2>
</div>

<div class="row justify-content-center fade-in">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" name="idMaterial" value="@idMaterial" />
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="nombreMaterial" class="form-control" value="@nombreMaterial" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripci&oacute;n</label>
                        <textarea name="descripcion" class="form-control" rows="3">@descripcion</textarea>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
