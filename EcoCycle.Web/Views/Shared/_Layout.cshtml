<!DOCTYPE html>
<html lang="es" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoCycle</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    @{
        var esAdmin = Context.Session.GetString("Rol") == "Admin";
    }

    <nav class="navbar navbar-ecocycle shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-recycle"></i> EcoCycle
            </a>
            <button class="navbar-toggler d-lg-none border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarLinks">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-lg-none" id="navbarLinks">
                <ul class="navbar-nav me-auto mt-2">
                    @if (!string.IsNullOrEmpty(Context.Session.GetString("Token")))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Materiales" asp-action="Index">
                                <i class="bi bi-box"></i> Materiales
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Publicaciones" asp-action="Index">
                                <i class="bi bi-megaphone"></i> Publicaciones
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="CentrosReciclaje" asp-action="Index">
                                <i class="bi bi-building"></i> Centros
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Recompensas" asp-action="Index">
                                <i class="bi bi-star"></i> Recompensas
                            </a>
                        </li>
                        @if (esAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reportes" asp-action="Index">
                                    <i class="bi bi-bar-chart"></i> Reportes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Configuracion" asp-action="Index">
                                    <i class="bi bi-gear"></i> Configuraci&oacute;n
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
            <ul class="navbar-nav ms-auto d-flex align-items-center gap-2">
                <li class="nav-item">
                    <button id="themeToggle" class="theme-toggle" title="Cambiar tema">
                        <i id="themeIcon" class="bi bi-moon-fill"></i>
                    </button>
                </li>
                @if (!string.IsNullOrEmpty(Context.Session.GetString("Token")))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-secondary" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span class="d-none d-md-inline">@Context.Session.GetString("Correo")</span>
                            @if (esAdmin)
                            {
                                <span class="badge bg-success ms-1">Admin</span>
                            }
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" class="dropdown-item">
                                        <i class="bi bi-box-arrow-right"></i> Cerrar Sesi&oacute;n
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesi&oacute;n
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Register">
                            <i class="bi bi-person-plus"></i> Registro
                        </a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        string IsActive(string controller, string? action = null)
        {
            var match = string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
            if (action != null)
                match = match && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
            return match ? "active" : "";
        }
    }

    <div class="container-fluid">
        <div class="row">
            @if (!string.IsNullOrEmpty(Context.Session.GetString("Token")))
            {
                <nav class="col-md-2 d-none d-md-block sidebar min-vh-100 p-3">
                    <div class="sidebar-sticky">
                        <h6 class="sidebar-heading">Navegaci&oacute;n</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Materiales", "Index")" asp-controller="Materiales" asp-action="Index">
                                    <i class="bi bi-box"></i> Materiales
                                </a>
                            </li>
                            @if (esAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Materiales", "Create")" asp-controller="Materiales" asp-action="Create">
                                        <i class="bi bi-plus-circle"></i> Nuevo Material
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Publicaciones", "Index")" asp-controller="Publicaciones" asp-action="Index">
                                    <i class="bi bi-megaphone"></i> Publicaciones
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Publicaciones", "Create")" asp-controller="Publicaciones" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i> Nueva Publicaci&oacute;n
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @IsActive("CentrosReciclaje", "Index")" asp-controller="CentrosReciclaje" asp-action="Index">
                                    <i class="bi bi-building"></i> Centros
                                </a>
                            </li>
                            @if (esAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("CentrosReciclaje", "Create")" asp-controller="CentrosReciclaje" asp-action="Create">
                                        <i class="bi bi-plus-circle"></i> Nuevo Centro
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link @IsActive("Recompensas")" asp-controller="Recompensas" asp-action="Index">
                                    <i class="bi bi-star"></i> Recompensas
                                </a>
                            </li>
                            @if (esAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Recompensas", "Create")" asp-controller="Recompensas" asp-action="Create">
                                        <i class="bi bi-plus-circle"></i> Nueva Recompensa
                                    </a>
                                </li>
                            }
                            @if (esAdmin)
                            {
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Reportes")" asp-controller="Reportes" asp-action="Index">
                                        <i class="bi bi-bar-chart"></i> Reportes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @IsActive("Configuracion")" asp-controller="Configuracion" asp-action="Index">
                                        <i class="bi bi-gear"></i> Configuraci&oacute;n
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </nav>
                <main role="main" class="col-md-10 ms-sm-auto px-4 py-4 fade-in">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            }
            else
            {
                <main role="main" class="col-12 px-4 py-4 fade-in">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            }
        </div>
    </div>

    <footer class="footer py-3 mt-auto">
        <div class="container text-center">
            &copy; 2026 EcoCycle &mdash; Sistema de Reciclaje
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
