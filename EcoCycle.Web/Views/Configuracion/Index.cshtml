@using System.Text.Json
@model List<JsonElement>

@{
    ViewData["Title"] = "Configuraci\u00F3n";
}

<div class="page-header">
    <h2><i class="bi bi-gear me-2"></i>Configuraci&oacute;n del Sistema</h2>
</div>

<div class="table-responsive fade-in">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Clave</th>
                <th>Valor</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.GetProperty("clave").GetString()</td>
                    <td>
                        <code>@item.GetProperty("valor").GetString()</code>
                    </td>
                    <td class="text-end">
                        <button class="btn btn-warning btn-sm" onclick="editar(@item.GetProperty("idConfiguracion").GetInt32(), '@item.GetProperty("clave").GetString()', '@item.GetProperty("valor").GetString()')">
                            <i class="bi bi-pencil me-1"></i>Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Update" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Editar Configuraci&oacute;n</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="idConfiguracion" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Clave</label>
                        <input type="text" class="form-control" id="editClave" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Valor</label>
                        <input type="text" name="valor" class="form-control" id="editValor" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Guardar</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editar(id, clave, valor) {
            document.getElementById('editId').value = id;
            document.getElementById('editClave').value = clave;
            document.getElementById('editValor').value = valor;
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }
    </script>
}
